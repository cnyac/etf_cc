{# 单文件自包含报告 - 双市场共用 #}
{# 变量约定：
   - market: "A" | "US"
   - label: 当前 session 的 label
   - session: 当前 session dict
   - history: 近 N 个 session（不含当前）
   - name_map: code -> 中文名
   - known_palette: list[{hex, name}]
   - market_label: "A 股" 或 "美股"
#}
{# ===================== Jinja macros ===================== #}
{% set _PERSONA_SPECIAL = ('what_kills_this_view', 'free_analysis',
                           'panorama_text', 'cross_validation_text',
                           'cross_asset_panorama',
                           'key_movers', 'prev_session_audit') %}

{% macro persona_card(field_name, title, data) %}
  <div class="persona-card{% if not data %} null{% endif %}">
    <div class="field-name">{{ title }}</div>
    {% if not data %}
      <div>—（候选 0 或字段缺失）</div>
    {% else %}
      {% for k, v in data.items() if k not in _PERSONA_SPECIAL %}
        <div class="kv"><span class="key">{{ field_label_cn.get(k, k) }}：</span>
          {% set h = v | humanize %}
          {% if h is string %}{{ h | panel_to_cn }}{% else %}{{ h }}{% endif %}
        </div>
      {% endfor %}
      {% if data.free_analysis %}
        <div class="free-analysis">{{ data.free_analysis | panel_to_cn }}</div>
      {% endif %}
      {% if data.panorama_text %}
        <div class="persona-section">
          <div class="persona-section-h">全景图（≥3 段）</div>
          <div class="persona-section-body">{{ data.panorama_text | panel_to_cn }}</div>
        </div>
      {% endif %}
      {% if data.cross_validation_text %}
        <div class="persona-section">
          <div class="persona-section-h">交叉验证</div>
          <div class="persona-section-body">{{ data.cross_validation_text | panel_to_cn }}</div>
        </div>
      {% endif %}
      {% if data.cross_asset_panorama %}
        <div class="persona-section">
          <div class="persona-section-h">跨资产全景</div>
          <div class="persona-section-body">{{ data.cross_asset_panorama | panel_to_cn }}</div>
        </div>
      {% endif %}
      {% if data.key_movers %}
        <div class="persona-section">
          <div class="persona-section-h">关键异动板块</div>
          <ul class="key-movers">
          {% for m in data.key_movers %}
            <li>
              <span class="km-sector">{{ m.sector | panel_to_cn }}</span> ·
              <span class="km-phen">{{ m.phenomenon | panel_to_cn }}</span><br>
              <span class="km-motive">动因：{{ m.motive | panel_to_cn }}</span><br>
              <span class="km-scenario">推演：{{ m.scenario | panel_to_cn }}</span>
            </li>
          {% endfor %}
          </ul>
        </div>
      {% endif %}
      {% if data.prev_session_audit %}
        <div class="prev-audit">
          <span class="prev-audit-label">预期审计：</span>
          <span class="audit-badge audit-{{ data.prev_session_audit.actual_vs_expected }}
                       auditor-{{ field_name|replace('_emotion_cycle','')|replace('_liquidity_focus','')
                                              |replace('_contrarian_check','')
                                              |replace('_macro_check','')|replace('_breadth_check','')
                                              |replace('_breakout_check','')|replace('_stage_check','') }}">
            {{ data.prev_session_audit.actual_vs_expected }}
          </span>
          {% if data.prev_session_audit.audit_note %}
            <span class="prev-audit-note">{{ data.prev_session_audit.audit_note }}</span>
          {% endif %}
        </div>
      {% endif %}
      {% if data.what_kills_this_view %}
        <div class="kills">证伪条件：{{ data.what_kills_this_view }}</div>
      {% endif %}
    {% endif %}
  </div>
{% endmacro %}

{# category_table 接 group list；每 group 渲染 1-3 行（按窗口里该 code 实际出现的时段数）。
   代码 / 名称 列跨整组 rowspan，不染色（视觉头部）；其它列每时段独立一行，
   含批注：每行独立、按该行所属时段的批注染色；仅当前时段（最末行）可点击编辑。
   F.1：旧叙事冻结原则——历史时段批注只读，不允许在本报告里改昨日的判断。 #}
{% macro category_table(groups) %}
<table>
  <thead>
    <tr>
      <th style="width:88px">代码</th>
      <th style="width:120px">名称</th>
      <th style="width:62px">时段</th>
      <th style="width:70px">涨幅</th>
      <th style="width:60px">差值</th>
      <th style="width:70px">量能</th>
      <th style="width:70px">价位</th>
      <th style="width:50px">均线</th>
      <th>标签 / LLM 点评</th>
      <th style="width:90px">预期审计</th>
      <th style="width:240px">批注（点击当前时段编辑）</th>
    </tr>
  </thead>
  <tbody>
  {% for g in groups %}
    {% set rs = g.rows|length %}
    {% for r in g.rows %}
      {% set f = r.factors or {} %}
      {% set pn = f.pct_normalized %}
      {% set outlier = (pn is not none and (pn > 2 or pn < -2)) %}
      <tr data-code="{{ g.code }}"
          {% if r.is_current %}data-row-current="true"{% endif %}
          class="tr-clickable{% if outlier %} outlier-row{% endif %}{% if loop.last and rs > 1 %} group-end{% endif %}"
          {% if r.annotation_color %}style="--row-bg:{{ r.annotation_color }};"{% endif %}>
        {% if loop.first %}
          <td rowspan="{{ rs }}" class="group-name-cell">{{ g.code[2:] if g.code|length > 6 else g.code }}{% if r.new_high_20d %} <span class="up">★</span>{% elif r.new_low_20d %} <span class="down">▼</span>{% endif %}{% if outlier %} <span class="warn">⚠</span>{% endif %}</td>
          <td rowspan="{{ rs }}" class="group-name-cell">{{ g.name or '' }}</td>
        {% endif %}
        <td class="center muted-small">{{ r.label_short }}</td>
        <td class="num">
          <span class="{{ pct_class(r.today_pct) }}">{{ pct_fmt(r.today_pct) }}</span><br>
          <span class="muted">{{ pct_fmt(r.yest_pct) }}</span>
        </td>
        {%- set rs_b = f.get('rs_vs_benchmark') -%}
        <td class="num"{% if rs_b is not none %} title="相对基准强度 {{ '%+.2f'|format(rs_b * 100) }}%（自身今涨幅 − 基准ETF今涨幅）"{% endif %}><span class="{{ pct_class(r.pct_diff) }}">{{ pct_fmt(r.pct_diff) }}</span></td>
        {%- set vstd = f.get('vol_std_20') -%}
        <td class="num"{% if vstd is not none %} title="20日收益率标准差 σ={{ '%.4f'|format(vstd) }}（这段时间整体颠不颠）"{% endif %}>
          {% if f.vol_ratio_20 is not none %}{{ '%.2fx'|format(f.vol_ratio_20) }}{% else %}—{% endif %}<br>
          <span class="muted">{% if f.vol_pctile_20 is not none %}P{{ f.vol_pctile_20 }}{% endif %}</span>
        </td>
        {%- set er = f.get('er60') -%}{%- set mdd = f.get('mdd60') -%}{%- set slp = f.get('slope_seg') -%}
        {%- set ns = namespace(tips=[]) -%}
        {%- if er is not none -%}{%- set ns.tips = ns.tips + ['60日路径效率 ' + ('%.2f'|format(er)) + '（1=平滑直线，越低越曲折）'] -%}{%- endif -%}
        {%- if mdd is not none -%}{%- set ns.tips = ns.tips + ['60日最大回撤 ' + ('%.1f'|format(mdd * 100)) + '%'] -%}{%- endif -%}
        {%- if slp -%}{%- set ns.tips = ns.tips + ['分段斜率 远/中/近 ' + ('%+.1f'|format(slp[0] * 100)) + '/' + ('%+.1f'|format(slp[1] * 100)) + '/' + ('%+.1f'|format(slp[2] * 100)) + '%'] -%}{%- endif -%}
        <td class="num"{% if ns.tips %} title="{{ ns.tips|join(' | ') }}"{% endif %}>
          {% if f.price_pctile_60 is not none %}P{{ f.price_pctile_60 }}{% else %}—{% endif %}<br>
          <span class="muted">{% if f.price_pctile_20 is not none %}P{{ f.price_pctile_20 }}{% endif %}</span>
        </td>
        <td class="center" title="收盘价 vs MA5 / MA20 / MA60（红=上方 蓝=下方 灰=近 ±0.5%）">
          <span class="ma-dots">
            <span class="ma-dot ma-dot-{{ f.close_vs_ma5 or 'na' }}" title="MA5"></span>
            <span class="ma-dot ma-dot-{{ f.close_vs_ma20 or 'na' }}" title="MA20"></span>
            <span class="ma-dot ma-dot-{{ f.close_vs_ma60 or 'na' }}" title="MA60"></span>
          </span>
        </td>
        <td>
          {% if r.feature %}
            <div class="tag-row">
            {% for tag in r.feature.split('，') %}
              <span class="badge {% if '龙1' in tag or '修复龙1' in tag %}badge-long1{% elif '最增量' in tag %}badge-vol-plus{% elif '最缩量' in tag %}badge-vol-minus{% endif %}">{{ tag }}</span>
            {% endfor %}
            </div>
          {% endif %}
          {% if r.analysis %}<div class="llm-analysis">{{ r.analysis | panel_to_cn }}</div>{% endif %}
        </td>
        <td class="center audit-cell">
          {% if r.audit and r.audit.actual_vs_expected %}
            <span class="audit-badge audit-{{ r.audit.actual_vs_expected }} auditor-{{ r.audit.auditor }}"
                  title="审计人：{{ r.audit.auditor }}">{{ r.audit.actual_vs_expected }}</span>
          {% else %}<span class="muted">—</span>{% endif %}
        </td>
        {% if r.is_current %}
          <td class="annotation-cell" data-anno-cell-for="{{ g.code }}">
            {% if r.annotation_note %}{{ r.annotation_note }}
            {% else %}<span class="muted ann-placeholder">点击行编辑批注</span>{% endif %}
          </td>
        {% else %}
          <td class="annotation-cell-historical" title="历史时段批注（只读；按禁区#10 旧叙事冻结）">
            {% if r.annotation_note %}{{ r.annotation_note }}
            {% else %}<span class="muted ann-placeholder">—</span>{% endif %}
          </td>
        {% endif %}
      </tr>
    {% endfor %}
  {% endfor %}
  </tbody>
</table>
{% endmacro %}

{% macro tracking_table(history, current, codes) %}
{% set recent = (history + [current])[-3:] %}
<table>
  <thead>
    <tr>
      <th>代码</th><th>名称</th>
      {% for s in recent %}<th>{{ s.label }}</th>{% endfor %}
      <th>20日走势</th><th>变化评级</th><th>评级理由</th>
    </tr>
  </thead>
  <tbody>
  {% for code in codes %}
    {% set name = name_map.get(code, '') %}
    <tr>
      <td>{{ code[2:] if code|length > 6 else code }}</td>
      <td>{{ name }}</td>
      {% for s in recent %}
        {% set t = (s.tickers | selectattr('code', 'equalto', code) | first) %}
        {% if t %}
          {% set f = t.factors or {} %}
          <td>
            <span class="{{ pct_class(t.today_pct) }}">{{ pct_fmt(t.today_pct) }}</span><br>
            <span class="muted">{% if f.vol_ratio_20 is not none %}{{ '%.1fx'|format(f.vol_ratio_20) }}{% endif %}</span><br>
            <span class="muted">{{ t.feature or '—' }}</span>
          </td>
        {% else %}<td class="muted">—</td>{% endif %}
      {% endfor %}
      <td>{{ sparkline(code) }}</td>
      {# 变化评级 + 评级理由 = 读 current session 该 code 的 audit（#8 修复 2026-05-22） #}
      {% set cur_t = (current.tickers | selectattr('code', 'equalto', code) | first) %}
      {% set au = cur_t.audit if cur_t else None %}
      <td class="center">
        {% if au and au.actual_vs_expected %}
          <span class="audit-badge audit-{{ au.actual_vs_expected }} auditor-{{ au.auditor or 'quant' }}"
                title="审计人：{{ au.auditor or 'quant' }}">{{ au.actual_vs_expected }}</span>
        {% else %}<span class="muted">—</span>{% endif %}
      </td>
      <td class="muted-2">{{ au.audit_note if (au and au.audit_note) else '—' }}</td>
    </tr>
  {% endfor %}
  </tbody>
</table>
{% endmacro %}

{% macro sparkline(code) %}
  {# 从 spark_data dict 取该 code 的真实收盘价序列 #}
  {% set pts = spark_data.get(code, []) %}
  {% if pts|length < 5 %}<span class="muted">—</span>{% else %}
    {% set w = 100 %}{% set h = 28 %}
    {% set hi = pts | max %}{% set lo = pts | min %}
    {% set rng = (hi - lo) if (hi - lo) > 0 else (hi if hi > 0 else 1) %}
    {% set last_x = (pts|length - 1) * (w / (pts|length - 1)) %}
    {% set last_y = h - ((pts[-1] - lo) / rng) * h %}
    {% set up = pts[-1] >= pts[0] %}
    <svg class="sparkline" width="{{w}}" height="{{h}}" viewBox="0 0 {{w}} {{h}}">
      <polyline fill="none" stroke="{{ '#FF0000' if up else '#00008B' }}" stroke-width="1.2"
        points="{%- for v in pts -%}{{ loop.index0 * (w / (pts|length - 1)) }},{{ h - ((v - lo) / rng) * h }} {% endfor -%}" />
      <circle cx="{{ last_x }}" cy="{{ last_y }}" r="2" fill="{{ '#FF0000' if up else '#00008B' }}" />
    </svg>
  {% endif %}
{% endmacro %}

{% macro matrix_view(sessions, codes) %}
{% set recent = sessions[-20:] %}
<table class="matrix-table">
  <thead>
    <tr>
      <th style="width:60px">代码</th>
      <th style="width:140px">名称</th>
      {% for s in recent %}<th>{{ s.label[5:10] if s.label|length > 10 else s.label }}</th>{% endfor %}
    </tr>
  </thead>
  <tbody>
  {% for code in codes %}
    <tr>
      <td><span class="muted">{{ code[2:] if code|length > 6 else code }}</span></td>
      <td>{{ name_map.get(code, '') }}</td>
      {% for s in recent %}
        {% set t = (s.tickers | selectattr('code', 'equalto', code) | first) %}
        {% if t %}
          {% set cls = {'持续强化': 'matrix-cell-c1', '反包修复': 'matrix-cell-c2', '强反转': 'matrix-cell-c3', '连续杀跌': 'matrix-cell-c4'}.get(t.category, '') %}
          <td class="{{ cls }}">
            {% if t.feature %}{{ t.feature.split('，')[0] }}{% else %}—{% endif %}
          </td>
        {% else %}<td>—</td>{% endif %}
      {% endfor %}
    </tr>
  {% endfor %}
  </tbody>
</table>
{% endmacro %}

<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<title>{{ label }} - {{ market_label }}量价分析</title>
<style>
:root {
  --color-up: #FF0000;
  --color-down: #00008B;
  --color-flat: #000000;
  --color-warn: #FFA500;
  --gray: #888;
  --gray-light: #ddd;
}
body {
  font-family: "仿宋_GB2312", "FangSong", "STFangsong", serif;
  font-size: 1.5em;
  color: #222;
  margin: 0;
  padding: 0 24px 80px 24px;
  background: #fafafa;
}
h1 {
  font-family: "华文中宋", "STZhongsong", "STSong", serif;
  font-size: 2em;
  font-weight: bold;
  margin: 24px 0 12px;
}
h2 {
  font-family: "黑体", "SimHei", sans-serif;
  font-size: 1.5em;
  font-weight: normal;
  margin: 24px 0 12px;
  border-left: 4px solid #555;
  padding-left: 10px;
}
h3 {
  font-family: "楷体_GB2312", "KaiTi", "STKaiti", serif;
  font-size: 1.5em;
  font-weight: bold;
  margin: 16px 0 8px;
}
.up { color: var(--color-up); }
.down { color: var(--color-down); }
.flat { color: var(--color-flat); }
.muted { color: var(--gray); font-size: 0.7em; }
.warn { color: var(--color-warn); font-weight: bold; }
.outlier-row td {
  border-top: 2px solid var(--color-warn) !important;
  border-bottom: 2px solid var(--color-warn) !important;
}
.outlier-row td:first-child {
  border-left: 4px solid var(--color-warn) !important;
}

table {
  width: 100%;
  border-collapse: collapse;
  margin: 8px 0 16px;
  background: white;
}
th, td {
  border: 1px solid var(--gray-light);
  padding: 6px 8px;
  vertical-align: top;
  font-size: 0.7em;
  text-align: left;
}
th {
  background: #f0f0f0;
  font-family: "黑体", sans-serif;
  font-weight: normal;
  text-align: center;
}
td.num { text-align: right; font-variant-numeric: tabular-nums; }
td.center { text-align: center; }

.badge {
  display: inline-block;
  padding: 2px 6px;
  margin-right: 4px;
  border-radius: 3px;
  font-size: 0.7em;
  background: #eee;
  border: 1px solid #ccc;
}
.badge-long1 { background: #ffe4e1; border-color: #ff9090; }
.badge-vol-plus { background: #ffe8e8; border-color: #ff7070; }
.badge-vol-minus { background: #e3f2fd; border-color: #42a5f5; }

/* 预期审计 badge — 紫边=量化审，红蓝边=人格审。颜色按评级方向。 */
.audit-badge {
  display: inline-block;
  padding: 2px 6px;
  border-radius: 3px;
  font-size: 0.8em;
  font-weight: bold;
  white-space: nowrap;
}
.audit-强超于预期 { background: #ffd6d6; color: #b00020; }
.audit-超于预期 { background: #ffeaea; color: #d32f2f; }
.audit-符合预期 { background: #f0f0f0; color: #555; }
.audit-低于预期 { background: #e3f0fa; color: #1565c0; }
.audit-强低于预期 { background: #d0e3f7; color: #002b5c; }
.auditor-quant { border: 2px solid #7e57c2; }
.auditor-yangjia,
.auditor-zhaolaoge,
.auditor-fengliu,
.auditor-discipline { border: 2px solid #888; }

/* §3 组分隔线：同品种最后一行底部加粗，方便区分组 */
.group-end td { border-bottom: 2px solid #aaa; }
.muted-small { color: var(--gray); font-size: 0.85em; }
.muted-2 { color: #555; font-size: 0.9em; }

/* persona-card 扩展子段 */
.persona-section {
  margin: 10px 0;
  padding: 8px 12px;
  background: #fafafa;
  border-left: 3px solid #ccc;
}
.persona-section-h {
  font-family: "黑体", sans-serif;
  font-size: 0.95em;
  font-weight: bold;
  margin-bottom: 4px;
}
.persona-section-body {
  font-family: "仿宋_GB2312", "FangSong", serif;
  line-height: 1.6;
}
.key-movers { margin: 6px 0; padding-left: 20px; }
.key-movers li { margin-bottom: 6px; }
.km-sector { font-weight: bold; }
.km-phen { color: #444; }
.km-motive, .km-scenario { color: #555; font-size: 0.9em; }

.prev-audit {
  margin: 8px 0;
  padding: 4px 8px;
  background: #f5f5f5;
  border-radius: 3px;
}
.prev-audit-label { font-weight: bold; margin-right: 6px; }
.prev-audit-note { color: #666; margin-left: 8px; font-size: 0.85em; }

/* §3.5 独特异象 */
.anomaly-card {
  background: #fff7e6;
  border-left: 5px solid #ff9800;
  padding: 14px 18px;
  margin: 10px 0 16px;
  font-family: "仿宋_GB2312", "FangSong", serif;
  line-height: 1.7;
}

/* §3 象限小结块（E.2 反馈 2）：紧贴分类表格下方的纯文本小结 */
.quadrant-summary {
  background: #f5f9fc;
  border-left: 4px solid #1565c0;
  padding: 10px 14px;
  margin: 4px 0 14px;
  font-family: "仿宋_GB2312", "FangSong", serif;
  font-size: 1.45em;
  line-height: 1.6;
}
.quadrant-summary .qs-label {
  font-family: "黑体", "SimHei", sans-serif;
  font-size: 0.95em;
  color: #1565c0;
  margin-right: 8px;
}
/* §3 组整体定性块：在所属组最后一个象限表后出现，过渡视角 */
.group-qualitative {
  background: #fff;
  border: 1px dashed #888;
  padding: 10px 14px;
  margin: 4px 0 18px;
  font-family: "仿宋_GB2312", "FangSong", serif;
  font-size: 1.45em;
  line-height: 1.6;
}
.group-qualitative .gq-label {
  font-family: "黑体", "SimHei", sans-serif;
  font-size: 0.95em;
  color: #333;
  margin-right: 8px;
}

/* §6 策略前瞻 */
.strategy-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 10px;
  margin: 10px 0 16px;
}
.sc-item {
  background: #fafafa;
  border-left: 3px solid #ccc;
  padding: 8px 12px;
}
.sc-wide { grid-column: span 3; }
.sc-risk { border-left-color: var(--color-warn); background: #fff7e6; }
.sc-key {
  font-family: "黑体", sans-serif;
  font-weight: bold;
  margin-right: 8px;
}
.sc-val { font-size: 1em; }
.sc-上涨 { color: var(--color-up); }
.sc-下跌 { color: var(--color-down); }
.sc-震荡 { color: #555; }
.sc-list { margin: 4px 0 0 16px; padding: 0; }
/* §6 deep_analysis 长篇综合论证（#9 2026-05-22） */
.deep-analysis-block {
  background: #fbfaf7;
  border-left: 4px solid #555;
  padding: 14px 20px;
  margin: 16px 0 24px;
}
.deep-analysis-block h3 {
  margin: 0 0 10px;
  /* h3 已有 楷体_GB2312 1.5em bold，继承即可，仅去掉默认外边距 */
}
.deep-analysis-body {
  font-family: "仿宋_GB2312", "FangSong", "STFangsong", serif;
  /* 与 §2 正文一致，body 1.5em 继承 */
  line-height: 1.75;
  text-align: justify;
}

/* §7 宏观周期 */
.macro-card {
  background: #f8f9fa;
  border-left: 6px solid #333;
  padding: 18px 22px;
  margin: 12px 0 18px;
}
.macro-h {
  font-family: "黑体", sans-serif;
  font-weight: bold;
  margin-top: 10px;
  margin-bottom: 4px;
}
.macro-body {
  font-family: "仿宋_GB2312", "FangSong", serif;
  line-height: 1.7;
}

.tag-row { margin-bottom: 4px; }
.llm-analysis {
  font-family: "仿宋_GB2312", "FangSong", serif;
  font-size: 0.95em;
  line-height: 1.5;
  color: #333;
  margin-top: 2px;
}
.annotation-cell,
.annotation-cell-historical {
  font-family: "仿宋_GB2312", "FangSong", serif;
  font-size: 0.95em;
  line-height: 1.5;
  color: #222;
  white-space: pre-wrap;
}
.annotation-cell .ann-placeholder,
.annotation-cell-historical .ann-placeholder { font-size: 0.85em; }

/* F.1：行级背景色——按各行所属时段的批注 annotation_color 染色，
   但 rowspan 的代码/名称列（.group-name-cell）保持中性，作为视觉头部。 */
tr[style*="--row-bg"] > td:not([rowspan]) {
  background-color: var(--row-bg);
}

/* 三球：红=above, 深蓝=below, 灰=near。避免绿色（用户色盲） */
.ma-dots { display: inline-flex; gap: 2px; align-items: center; }
.ma-dot {
  display: inline-block;
  width: 10px; height: 10px;
  border-radius: 50%;
  border: 1px solid #999;
  font-size: 0;
}
.ma-dot-above { background: #FF0000; }
.ma-dot-below { background: #00008B; }
.ma-dot-near { background: #cccccc; }
.ma-dot-na { background: transparent; }

.cross-asset {
  display: flex;
  flex-wrap: wrap;
  gap: 12px 24px;
  padding: 6px 0;
}
.cross-asset .item {
  /* 与 §2 时段叙事正文一致（继承 body 1.5em） */
  font-size: 1em;
}
.cross-asset .item .dim-label { color: #444; margin-right: 4px; }

.panel-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(120px, 1fr));
  gap: 8px;
  margin: 8px 0;
}
.panel-cell {
  background: white;
  border: 1px solid var(--gray-light);
  padding: 8px;
  border-radius: 4px;
}
.panel-cell .label { font-size: 0.6em; color: var(--gray); }
.panel-cell .value { font-size: 0.9em; font-weight: bold; margin-top: 2px; }

.persona-card {
  background: white;
  border: 1px solid var(--gray-light);
  border-left: 4px solid #888;
  padding: 12px;
  margin: 8px 0;
  font-size: 0.7em;
}
.persona-card .field-name {
  font-family: "黑体", sans-serif;
  font-weight: bold;
  font-size: 0.9em;
  color: #444;
  margin-bottom: 6px;
}
.persona-card .kv { margin: 4px 0; }
.persona-card .key { color: var(--gray); margin-right: 6px; }
.persona-card.null { opacity: 0.5; font-style: italic; }
.persona-card .kills {
  border-top: 1px dashed #ccc;
  margin-top: 6px;
  padding-top: 6px;
  font-size: 0.85em;
  color: #555;
}
.persona-card .free-analysis {
  margin-top: 10px;
  padding: 8px 10px;
  background: #fafafa;
  border-radius: 3px;
  font-family: "仿宋_GB2312", "FangSong", serif;
  font-size: 1em;
  line-height: 1.6;
  color: #222;
}

.sparkline { display: inline-block; vertical-align: middle; }

.matrix-table td {
  font-size: 0.6em;
  text-align: center;
  padding: 3px 4px;
}
.matrix-cell-c1 { background: #ffebee; }  /* 持续强化 浅红 */
.matrix-cell-c2 { background: #fce4ec; }  /* 反包修复 浅粉 */
.matrix-cell-c3 { background: #e3f2fd; }  /* 强反转 浅蓝 */
.matrix-cell-c4 { background: #f5f5f5; }  /* 连续杀跌 灰 */

#unsaved-banner {
  position: sticky;
  top: 0;
  background: var(--color-up);
  color: white;
  padding: 8px;
  text-align: center;
  display: none;
  z-index: 100;
  font-size: 0.8em;
}
#unsaved-banner.show { display: block; }

#save-watermark {
  position: fixed;
  right: 12px;
  bottom: 12px;
  font-size: 0.5em;
  color: var(--gray);
  background: rgba(255,255,255,0.9);
  padding: 4px 8px;
  border-radius: 3px;
}

.annotation-cell { cursor: pointer; }
.annotation-cell:hover { background: #fffbeb; outline: 2px solid #f5d28a; outline-offset: -2px; }
/* 历史时段批注（只读）：默认光标 + 无 hover 高亮，提示用户这是只读区 */
.annotation-cell-historical { cursor: default; }

#ann-modal {
  display: none;
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.4);
  z-index: 200;
  align-items: center;
  justify-content: center;
}
#ann-modal.show { display: flex; }
#ann-modal .box {
  background: white;
  padding: 20px;
  border-radius: 6px;
  min-width: 320px;
  max-width: 480px;
  font-size: 0.7em;
}
#ann-modal h3 { margin-top: 0; font-size: 1em; }
#ann-modal .palette { display: flex; flex-wrap: wrap; gap: 6px; margin: 8px 0; }
#ann-modal .swatch {
  width: 28px; height: 28px;
  border: 2px solid #ccc;
  border-radius: 4px;
  cursor: pointer;
}
#ann-modal .swatch.selected { border-color: #222; border-width: 3px; }
#ann-modal textarea {
  width: 100%;
  font-family: inherit;
  font-size: 1em;
  padding: 6px;
  margin-top: 6px;
  box-sizing: border-box;
  min-height: 60px;
}
#ann-modal .actions { margin-top: 12px; text-align: right; }
#ann-modal button {
  font-family: inherit;
  font-size: 0.9em;
  padding: 4px 14px;
  margin-left: 6px;
  cursor: pointer;
}

#save-btn {
  position: fixed;
  right: 12px;
  bottom: 50px;
  font-family: inherit;
  font-size: 0.8em;
  padding: 8px 16px;
  background: var(--color-up);
  color: white;
  border: none;
  border-radius: 4px;
  cursor: pointer;
  z-index: 50;
}
</style>
</head>
<body>

<div id="unsaved-banner">⚠ 有未保存的批注，请点击右下角"保存"按钮下载新文件</div>

<h1>{{ label }}（{{ market_label }}）</h1>

{# ============ §0 极值共振预警（仅触发时显示）============ #}
{% if session.panel.breadth_alert == "bullish_resonance" %}
<div style="background-color:#ffe6e6;color:#FF0000;font-size:2em;font-family:'华文中宋',serif;font-weight:bold;text-align:center;padding:22px;border:6px solid #FF0000;margin:20px 0;box-shadow:0 4px 12px rgba(255,0,0,0.4);letter-spacing:2px;">
🚨 全局极值预警：超 70% 品种共振起爆！做多情绪极度宣泄，注意逼空动能 🚨
</div>
{% elif session.panel.breadth_alert == "bearish_resonance" %}
<div style="background-color:#e6f0fa;color:#00008B;font-size:2em;font-family:'华文中宋',serif;font-weight:bold;text-align:center;padding:22px;border:6px solid #00008B;margin:20px 0;box-shadow:0 4px 12px rgba(0,0,139,0.4);letter-spacing:2px;">
⚠ 全局极值预警：超 70% 品种共振杀跌！流动性急剧收缩，防守退潮信号 ⚠
</div>
{% endif %}

{# ============ §1 盘面概览 ============ #}
<h2>§1 盘面概览</h2>
{% set p = session.panel %}
<div class="panel-grid">
  <div class="panel-cell">
    <div class="label">上涨/下跌/平</div>
    <div class="value"><span class="up">{{ p.up_count }}</span> / <span class="down">{{ p.down_count }}</span> / {{ p.flat_count }}</div>
  </div>
  <div class="panel-cell">
    <div class="label">强势/强跌</div>
    <div class="value"><span class="up">{{ p.strong_up_count }}</span> / <span class="down">{{ p.strong_down_count }}</span></div>
  </div>
  <div class="panel-cell">
    <div class="label">量能扩张/收缩</div>
    <div class="value">{{ p.vol_expansion_count }} / {{ p.vol_contraction_count }}</div>
  </div>
  <div class="panel-cell">
    <div class="label">20日新高/新低</div>
    <div class="value"><span class="up">{{ p.new_high_count_20d }}</span> / <span class="down">{{ p.new_low_count_20d }}</span></div>
  </div>
  {% if market == "US" %}
  <div class="panel-cell">
    <div class="label">站上 MA150</div>
    <div class="value">{{ p.above_ma150_count }}</div>
  </div>
  <div class="panel-cell">
    <div class="label">SPY-IWM 分化</div>
    <div class="value">
      {% set d = p.spy_iwm_divergence %}
      {% if d is none %}—{% else %}
      <span class="{{ 'up' if d > 0 else ('down' if d < 0 else 'flat') }}">
        {{ '%+.2f%%'|format(d * 100) }}
      </span>
      {% endif %}
    </div>
  </div>
  {% endif %}
</div>

<h3>分类分布</h3>
{% set cd = p.category_distribution or {} %}
{% set total = (p.up_count + p.down_count + p.flat_count) or 1 %}
{% set dom = cd.items() | list | sort(attribute=1, reverse=True) | first %}
<div class="cross-asset">
{% for cat in ['持续强化', '反包修复', '强反转', '连续杀跌'] %}
  {% set n = cd.get(cat, 0) %}
  {% set pct = (n / total * 100) | round(1) %}
  <div class="item">
    <span class="dim-label">{{ cat }}：</span><b>{{ n }}</b>
    <span class="muted">（{{ pct }}%{% if dom and cat == dom[0] %} · 主导{% endif %}）</span>
  </div>
{% endfor %}
</div>

<h3>跨资产</h3>
<div class="cross-asset">
{% for dim, val in p.cross_asset_state.items() %}
  <div class="item">
    <span class="dim-label">{{ cross_asset_label_cn.get(dim, dim) }}：</span>
    {% if val == "up" %}<span class="up">↑ 上涨</span>
    {% elif val == "down" %}<span class="down">↓ 下跌</span>
    {% elif val == "flat" %}<span class="flat">— 持平</span>
    {% else %}<span class="muted">暂无数据</span>{% endif %}
  </div>
{% endfor %}
</div>
{# §3 内容层 cross_asset_panorama 待 #3 完整实施时由 LLM 输出，本次仅显示层中文化 #}

{# ============ §2 双引擎人格 ============ #}
<h2>§2 时段叙事</h2>
{% set n = session.narrative %}
{% if n %}
  {% if n.is_skeleton %}
    <p class="muted">[骨架 Python 生成] {{ n.session_summary | panel_to_cn }}</p>
  {% else %}
    <p>{{ n.session_summary | panel_to_cn }}</p>
  {% endif %}

  {% if not n.is_skeleton %}
    {% if market == "A" %}
      {{ persona_card("yangjia_emotion_cycle", "炒股养家 · 情绪周期", n.yangjia_emotion_cycle) }}
      {{ persona_card("zhaolaoge_liquidity_focus", "赵老哥 · 流动性聚焦", n.zhaolaoge_liquidity_focus) }}
      {{ persona_card("fengliu_contrarian_check", "冯柳 · 逆向赔率", n.fengliu_contrarian_check) }}
    {% else %}
      {{ persona_card("druckenmiller_macro_check", "德鲁肯米勒 · 宏观跨资产", n.druckenmiller_macro_check) }}
      {{ persona_card("minervini_breadth_check", "米奈尔维尼 · 市场广度", n.minervini_breadth_check) }}
      {{ persona_card("wyckoff_breakout_check", "威科夫 · 突破质量", n.wyckoff_breakout_check) }}
      {{ persona_card("weinstein_stage_check", "温斯坦 · 阶段判定", n.weinstein_stage_check) }}
    {% endif %}
  {% endif %}
{% else %}
  <p class="muted">narrative 未生成</p>
{% endif %}

{# ============ §3 四分类表 ============ #}
<h2>§3 分类详情</h2>
{% set qs_map = (n.quadrant_summaries if n else {}) or {} %}
{% set gq = (n.group_qualitative if n else {}) or {} %}
{% for cat in ['持续强化', '反包修复', '强反转', '连续杀跌'] %}
  {% set rows = tickers_by_cat[cat] %}
  {% if rows %}
    <h3>{{ cat }}（{{ rows|length }} 只）</h3>
    {{ category_table(rows) }}
    {% set qs = qs_map.get(cat) %}
    {% if qs %}
      <div class="quadrant-summary"><span class="qs-label">【{{ cat }} · 小结】</span>{{ qs | panel_to_cn }}</div>
    {% endif %}
  {% endif %}
  {# 多头组（持续强化+反包修复）末尾插入多头组整体定性 #}
  {% if cat == '反包修复' and gq.get('bull_group') %}
    <div class="group-qualitative"><span class="gq-label">【多头组整体定性】</span>{{ gq.bull_group | panel_to_cn }}</div>
  {% endif %}
  {# 空头组（强反转+连续杀跌）末尾插入空头组整体定性 #}
  {% if cat == '连续杀跌' and gq.get('bear_group') %}
    <div class="group-qualitative"><span class="gq-label">【空头组整体定性】</span>{{ gq.bear_group | panel_to_cn }}</div>
  {% endif %}
{% endfor %}

{# ============ §3.5 独特异象追踪（炒家专项；无独特品种时跳过）============ #}
{% if n and not n.is_skeleton and n.unique_anomaly_analysis %}
<h2>§3.5 独特异象追踪（炒家专项）</h2>
<div class="anomaly-card">{{ n.unique_anomaly_analysis | panel_to_cn }}</div>
{% endif %}

{# ============ §4 跨日追踪表 ============ #}
{% if history|length >= 1 %}
<h2>§4 跨日追踪（最近 3 时段）</h2>
{{ tracking_table(history, session, tracking_codes) }}
{% endif %}

{# ============ §5 20 时段矩阵 ============ #}
{% if matrix_codes %}
<h2>§5 20 时段矩阵概览</h2>
{{ matrix_view(history + [session], matrix_codes) }}
{% endif %}

{# ============ §6 策略前瞻（养家 6 项 + 炒家风险点）============ #}
{% if n and not n.is_skeleton and n.strategy_outlook %}
{% set so = n.strategy_outlook %}
<h2>§6 策略前瞻</h2>
<div class="strategy-grid">
  <div class="sc-item"><span class="sc-key">市场阶段</span><span class="sc-val">{{ so.market_phase }}</span></div>
  <div class="sc-item"><span class="sc-key">大势预判</span><span class="sc-val sc-{{ so.trend_forecast }}">{{ so.trend_forecast }}</span></div>
  <div class="sc-item"><span class="sc-key">风格定调</span><span class="sc-val">{{ so.style_tone }}</span></div>
  <div class="sc-item sc-wide"><span class="sc-key">主攻方向</span><span class="sc-val">{{ so.attack_direction }}</span></div>
  <div class="sc-item sc-wide"><span class="sc-key">出逃方向</span><span class="sc-val">{{ so.retreat_direction }}</span></div>
  {% if so.key_focus %}
  <div class="sc-item sc-wide">
    <span class="sc-key">核心关注</span>
    <ul class="sc-list">{% for kf in so.key_focus %}<li>{{ kf }}</li>{% endfor %}</ul>
  </div>
  {% endif %}
  {% if so.risk_points %}
  <div class="sc-item sc-wide sc-risk">
    <span class="sc-key">风险点（炒家专项）</span>
    <ul class="sc-list">{% for rp in so.risk_points %}<li>{{ rp }}</li>{% endfor %}</ul>
  </div>
  {% endif %}
</div>
{# deep_analysis 长篇综合论证（#9 2026-05-22）：以独立块展示，4 部分结构由 LLM 自由分段 #}
{% if so.deep_analysis %}
<div class="deep-analysis-block">
  <h3>深度综合论证</h3>
  <div class="deep-analysis-body">{{ so.deep_analysis | panel_to_cn | replace("\n", "<br>") | safe }}</div>
</div>
{% endif %}
{% endif %}

{# ============ §7 宏观周期定位与历史极值映射（仅周末收盘）============ #}
{% if n and not n.is_skeleton and n.macro_cycle_anchor %}
{% set mc = n.macro_cycle_anchor %}
<h2>§7 宏观周期定位（养家 × 炒家联合）</h2>
<div class="macro-card">
  <div class="macro-h">资产图谱</div>
  <div class="macro-body">{{ mc.asset_profile }}</div>

  {% if mc.historical_anchor %}
  <div class="macro-h">历史极值时空定位</div>
  <div class="macro-body">
    <strong>{{ mc.historical_anchor.year }}</strong> ·
    {{ mc.historical_anchor.event }} ·
    阶段：{{ mc.historical_anchor.phase }}<br>
    <span class="muted-2">{{ mc.historical_anchor.brief }}</span>
  </div>
  {% endif %}

  {% if mc.then_vs_now %}
  <div class="macro-h">跨时空异同</div>
  <div class="macro-body">
    <div><strong>形似：</strong>{{ mc.then_vs_now.similarity }}</div>
    <div><strong>神异：</strong>{{ mc.then_vs_now.divergence }}</div>
  </div>
  {% endif %}

  {% if mc.forward_strategy %}
  <div class="macro-h">沙盘推演与实战警告</div>
  <div class="macro-body">
    <div><strong>黑天鹅风险：</strong>{{ mc.forward_strategy.risks }}</div>
    <div><strong>隐蔽机会：</strong>{{ mc.forward_strategy.opportunities }}</div>
  </div>
  {% endif %}
</div>
{% endif %}

<button id="save-btn">保存</button>
<div id="save-watermark">未保存</div>

<div id="ann-modal">
  <div class="box">
    <h3 id="ann-ticker"></h3>
    <div>颜色：</div>
    <div class="palette" id="ann-palette"></div>
    <div>自选 hex (浅色 6 位)：<input id="ann-custom-hex" type="text" placeholder="#RRGGBB" style="width: 100px"></div>
    <div style="margin-top: 10px;">备注：</div>
    <textarea id="ann-note" placeholder="写下你的观察 / 关注理由"></textarea>
    <div class="actions">
      <button id="ann-clear">清除批注</button>
      <button id="ann-cancel">取消</button>
      <button id="ann-confirm">确定</button>
    </div>
  </div>
</div>

{# ============ 内嵌数据 ============ #}
<script type="application/json" id="snapshot">{{ snapshot_payload | tojson }}</script>
<script type="application/json" id="annotations">{{ annotations_payload | tojson }}</script>
<script type="application/json" id="known_palette">{{ known_palette | tojson }}</script>

<script>
{% raw %}
// ---------- 状态 ----------
const SNAPSHOT = JSON.parse(document.getElementById('snapshot').textContent);
const LABEL = SNAPSHOT.label;
const MARKET = SNAPSHOT.market;
const STORAGE_KEY = `etf_cc::${MARKET}::${LABEL}`;

let annotations = JSON.parse(document.getElementById('annotations').textContent) || {};
let knownPalette = JSON.parse(document.getElementById('known_palette').textContent) || [];
let dirty = false;
let fileHandle = null;

// 启动：localStorage 优先恢复（如果比内嵌新）
try {
  const cached = localStorage.getItem(STORAGE_KEY);
  if (cached) {
    const parsed = JSON.parse(cached);
    if (parsed && parsed.annotations) {
      annotations = parsed.annotations;
      dirty = parsed.dirty || false;
      applyAllRowStyles();
      if (dirty) showUnsaved();
    }
  }
} catch (e) { console.warn('localStorage 恢复失败', e); }

applyAllRowStyles();

// ---------- 工具 ----------
function $(id) { return document.getElementById(id); }
function saveToLocal() {
  try {
    localStorage.setItem(STORAGE_KEY, JSON.stringify({annotations, dirty}));
  } catch (e) { console.warn('localStorage 写入失败', e); }
}
function showUnsaved() {
  dirty = true;
  $('unsaved-banner').classList.add('show');
  $('save-watermark').textContent = '未保存';
}
function showSaved(ts) {
  dirty = false;
  $('unsaved-banner').classList.remove('show');
  $('save-watermark').textContent = '已保存 ' + ts;
}
// F.1：批注按行独立 + 只有当前时段（data-row-current）可编辑。
// applyRowStyle 仅更新当前时段那一行（历史行的批注是 server-render 静态产物，不动）。
function applyRowStyle(code) {
  const tr = document.querySelector(`tr[data-code="${code}"][data-row-current="true"]`);
  if (!tr) return;
  const ann = annotations[code];
  const cell = document.querySelector(`[data-anno-cell-for="${code}"]`);
  if (ann && ann.color) {
    tr.style.setProperty('--row-bg', ann.color);
    tr.title = ann.note || '';
    if (cell) {
      cell.innerHTML = '';
      if (ann.note) {
        cell.textContent = ann.note;
      } else {
        cell.innerHTML = '<span class="muted ann-placeholder">（已涂色，无备注）</span>';
      }
    }
  } else {
    tr.style.removeProperty('--row-bg');
    tr.title = '';
    if (cell) {
      cell.innerHTML = '<span class="muted ann-placeholder">点击行编辑批注</span>';
    }
  }
}
function applyAllRowStyles() {
  document.querySelectorAll('tr[data-code][data-row-current="true"]').forEach(
    tr => applyRowStyle(tr.dataset.code));
}

// ---------- modal ----------
let modalCode = null;
let modalColor = null;
function openModal(code) {
  modalCode = code;
  const ann = annotations[code] || {};
  modalColor = ann.color || null;
  $('ann-ticker').textContent = code + (SNAPSHOT.name_map[code] ? ' ' + SNAPSHOT.name_map[code] : '');
  $('ann-note').value = ann.note || '';
  $('ann-custom-hex').value = '';
  renderPalette();
  $('ann-modal').classList.add('show');
}
function renderPalette() {
  const html = knownPalette.map(c => {
    const sel = c.hex.toUpperCase() === (modalColor || '').toUpperCase() ? ' selected' : '';
    return `<div class="swatch${sel}" style="background:${c.hex}" data-hex="${c.hex}" title="${c.name||c.hex}"></div>`;
  }).join('');
  $('ann-palette').innerHTML = html;
  $('ann-palette').querySelectorAll('.swatch').forEach(sw => {
    sw.addEventListener('click', () => {
      modalColor = sw.dataset.hex;
      renderPalette();
    });
  });
}
function closeModal() {
  $('ann-modal').classList.remove('show');
  modalCode = null;
  modalColor = null;
}
$('ann-cancel').addEventListener('click', closeModal);
$('ann-confirm').addEventListener('click', () => {
  // 自选 hex 优先
  const custom = $('ann-custom-hex').value.trim();
  if (custom) {
    if (!/^#[0-9A-Fa-f]{6}$/.test(custom)) {
      alert('hex 格式错误，应为 #RRGGBB');
      return;
    }
    modalColor = custom.toUpperCase();
    // 合并进 known_palette（如果是新颜色）
    if (!knownPalette.find(c => c.hex.toUpperCase() === modalColor)) {
      knownPalette.push({hex: modalColor, name: modalColor});
    }
  }
  if (!modalColor) {
    alert('请选颜色或填 hex');
    return;
  }
  const note = $('ann-note').value.trim();
  annotations[modalCode] = {color: modalColor, note: note};
  applyRowStyle(modalCode);
  showUnsaved();
  saveToLocal();
  closeModal();
});
$('ann-clear').addEventListener('click', () => {
  delete annotations[modalCode];
  applyRowStyle(modalCode);
  showUnsaved();
  saveToLocal();
  closeModal();
});

// 批注单元格点击（只在"批注"列响应，不污染其它单元格的选区操作）
document.querySelectorAll('td.annotation-cell').forEach(cell => {
  cell.addEventListener('click', () => openModal(cell.dataset.annoCellFor));
});

// ---------- 保存 ----------
async function rebuildHtmlBlob() {
  // 重新生成完整 HTML：把当前 annotations 和 knownPalette 写回 script tag，其它不动
  const html = document.documentElement.outerHTML;
  // 用更可靠的方式：克隆 document，修改 script 标签
  const doc = document.implementation.createHTMLDocument('');
  doc.documentElement.innerHTML = document.documentElement.innerHTML;
  doc.getElementById('annotations').textContent = JSON.stringify(annotations);
  doc.getElementById('known_palette').textContent = JSON.stringify(knownPalette);
  // 清掉 banner show 状态
  const banner = doc.getElementById('unsaved-banner');
  if (banner) banner.classList.remove('show');
  return '<!DOCTYPE html>\n' + doc.documentElement.outerHTML;
}

async function saveViaFsa() {
  if (!window.showSaveFilePicker) return false;
  try {
    if (!fileHandle) {
      fileHandle = await window.showSaveFilePicker({
        suggestedName: LABEL + '.html',
        types: [{description: 'HTML', accept: {'text/html': ['.html']}}],
      });
    }
    const writable = await fileHandle.createWritable();
    const html = await rebuildHtmlBlob();
    await writable.write(html);
    await writable.close();
    return true;
  } catch (e) {
    console.warn('FSA 保存失败', e);
    return false;
  }
}

async function saveViaDownload() {
  const html = await rebuildHtmlBlob();
  const blob = new Blob([html], {type: 'text/html'});
  const a = document.createElement('a');
  a.href = URL.createObjectURL(blob);
  a.download = LABEL + '.html';
  a.click();
  setTimeout(() => URL.revokeObjectURL(a.href), 5000);
  return true;
}

$('save-btn').addEventListener('click', async () => {
  let ok = await saveViaFsa();
  if (!ok) ok = await saveViaDownload();
  if (ok) {
    const ts = new Date().toLocaleTimeString();
    showSaved(ts);
    try { localStorage.removeItem(STORAGE_KEY); } catch (e) {}
  }
});

// 拦截关闭
window.addEventListener('beforeunload', (e) => {
  if (dirty) {
    e.preventDefault();
    e.returnValue = '';
  }
});
